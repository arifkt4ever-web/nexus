pipeline {
    agent any

    environment {
        GIT_REPO = "https://github.com/latheef-mvmc/jenkins-terraform.git"
        NEXUS_URL = "http://192.168.19.129:8081/repository/terraformartifacts"
        BRANCH = "dev"
    }

    options {
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: "${BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Find Latest tfplan from Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    script {
                        def latestPlan = sh(
                            script: """
                            curl -s -u $USER:$PASS ${NEXUS_URL}/ | \
                            grep -o 'tfplan-${BRANCH}-[0-9]*' | \
                            sort -V | tail -n 1
                            """,
                            returnStdout: true
                        ).trim()

                        env.TF_PLAN_NAME = latestPlan
                        echo "Latest plan: ${env.TF_PLAN_NAME}"
                    }
                }
            }
        }

        stage('Download tfplan') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh """
                    echo "Downloading ${TF_PLAN_NAME}"
                    curl -u $USER:$PASS -O ${NEXUS_URL}/${TF_PLAN_NAME}
                    """
                }
            }
        }

        stage('Verify tfplan') {
            steps {
                sh "ls -l ${TF_PLAN_NAME}"
            }
        }

        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('Apply Terraform Plan') {
            steps {
                sh "terraform apply -auto-approve ${TF_PLAN_NAME}"
            }
        }
    }

    post {
        success {
            echo "✅ Applied ${TF_PLAN_NAME}"
        }
        failure {
            echo "❌ Apply failed"
        }
    }
}
