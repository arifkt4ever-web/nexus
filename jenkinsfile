pipeline {
    agent any

    environment {
        GIT_REPO = "https://github.com/arifkt4ever-web/nexus.git"
        BRANCH = "dev"
        NEXUS_URL = "http://192.168.228.128:8081/repository/terraform-artifacts/"
        TF_PLAN_NAME = "tfplan-dev-17"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: "${BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Download tfplan') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-id',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                    echo "Downloading $TF_PLAN_NAME"
                    curl -u $USER:$PASS -O $NEXUS_URL/$TF_PLAN_NAME
                    '''
                }
            }
        }

        stage('Verify') {
            steps {
                sh 'ls -l'
            }
        }

        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('Apply') {
            steps {
                sh 'terraform apply -auto-approve $TF_PLAN_NAME'
            }
        }
    }

    post {
        success {
            echo "✅ Apply completed successfully"
        }
        failure {
            echo "❌ Apply failed"
        }
    }
}
