pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        AWS_REGION = "ap-south-1"
        NEXUS_URL = "http://192.168.19.129:8081/repository/terraformartifacts"
    }

    stages {

        // 🔴 Ignore unwanted branches
        stage('Check Branch') {
            when {
                not {
                    anyOf {
                        branch 'dev'
                        branch 'qa'
                        branch 'prod'
                    }
                }
            }
            steps {
                echo "Skipping branch: ${env.BRANCH_NAME}"
                error("Stopping pipeline for non-target branch")
            }
        }

        stage('Checkout') {
            steps {
                echo "Using branch: ${env.BRANCH_NAME}"
            }
        }

        // 🔹 Terraform Init
        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }

        // 🔹 Workspace Selection
        stage('Select Workspace') {
            steps {
                script {
                    def ws = env.BRANCH_NAME
                    sh """
                    terraform workspace list | grep ${ws} || terraform workspace new ${ws}
                    terraform workspace select ${ws}
                    """
                }
            }
        }

        // 🔹 Validate
        stage('Terraform Validate') {
            steps {
                sh 'terraform validate'
            }
        }

        // 🔹 Plan
        stage('Terraform Plan') {
            steps {
                sh """
                terraform plan -var-file=${env.BRANCH_NAME}.tfvars -out=tfplan
                """
            }
        }

        // 🔥 Upload tfplan to Nexus (FIXED + DEBUG)
        stage('Upload tfplan to Nexus') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh '''
                    echo "===== Upload Stage START ====="

                    echo "Current directory:"
                    pwd

                    echo "Listing all files:"
                    ls -l

                    echo "Checking tfplan file:"
                    ls -l tfplan || { echo "❌ tfplan not found"; exit 1; }

                    echo "Uploading tfplan to Nexus..."

                    curl -v -u $NEXUS_USER:$NEXUS_PASS \
                    --upload-file tfplan \
                    http://192.168.19.129:8081/repository/terraformartifacts/tfplan-${BRANCH_NAME}-${BUILD_NUMBER}

                    echo "===== Upload Stage END ====="
                    '''
                }
            }
        }

        // 🔴 Approval for PROD
        stage('Approval for PROD') {
            when {
                branch 'prod'
            }
            steps {
                input message: "Approve Production Deployment?"
            }
        }

        // 🔹 Apply
        stage('Terraform Apply') {
            when {
                anyOf {
                    branch 'dev'
                    branch 'qa'
                    branch 'prod'
                }
            }
            steps {
                sh "terraform apply -auto-approve tfplan"
            }
        }
    }

    post {
        success {
            echo "✅ Terraform + Nexus upload successful"
        }
        failure {
            echo "❌ Pipeline failed"
        }
    }
}
